---
import WorkItem from './WorkItem.astro'
const currentPath = Astro.url.pathname

interface Props {
  className: string
}
const { className } = Astro.props

const WORKSTYPES = [
  {
    title: 'Eventos',
    source: '/portadas-trabajos/eventos-portada.webm',
    style: 'md:ml-[25%]',
    src: '/eventos'
  },
  {
    title: 'Bodas',
    source: '/portadas-trabajos/bodas-portada.webm',
    src: '/bodas'
  },
  {
    title: 'Restauración',
    source: '/portadas-trabajos/restaurantes-portada.webm',
    src: '/restaurantes'
  },
  {
    title: 'Corporativos y Marcas',
    source: '/portadas-trabajos/corporativo-portada.webm',
    src: '/corporativos'
  },
  {
    title: 'Deportes',
    source: '/portadas-trabajos/deportes-portada.webm',
    src: '/deportes'
  },
  {
    title: 'Moda',
    source: '/portadas-trabajos/moda-portada.webm',
    src: '/moda'
  },
  // {
  //   title: 'Educacion',
  //   source: '/portadas-trabajos/eduacion-portada.webm',
  //   src: '/educacion'
  // },
  {
    title: 'Alimentación',
    source: '/portadas-trabajos/alimentacion-portada.webm',
    src: '/alimentacion'
  },
  {
    title: 'Cortometraje',
    source: '/portadas-trabajos/cortometraje-portada.webm',
    style: 'md:mr-[25%]',
    src: '/cortometraje'
  }
]
---

<div class={`relative w-full h-dvh ${className}`}>
  <ul
    id='scroll-container'
    class='list-none flex w-full h-full overflow-x-scroll md:overflow-x-hidden snap-x snap-mandatory md:snap-none whitespace-nowrap gap-6 md:gap-24'>
    {
      WORKSTYPES.map((work) => (
        <li
          class={`snap-center w-[88vw] md:w-auto ${work.style || ''} h-dvh flex flex-none items-center justify-center text-2xl xl:text-9xl lg:text-7xl md:text-5xl sm:text-4xl ${className}`}>
          <WorkItem {...work} />
        </li>
      ))
    }
  </ul>

  <!-- Dots indicator: solo mobile -->
  <div
    id='slider-dots'
    class='md:hidden flex justify-center items-center gap-2 absolute bottom-6 left-0 right-0'>
    {
      WORKSTYPES.map((_, i) => (
        <button
          class={`h-[3px] rounded-full transition-all duration-300 ${i === 0 ? 'w-6 bg-white' : 'w-2 bg-white/35'}`}
          data-index={i}
        />
      ))
    }
  </div>
</div>

<style>
  /* Oculta scrollbar en todos los navegadores */
  #scroll-container {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #scroll-container::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  const scrollContainer = document.querySelector(
    '#scroll-container'
  ) as HTMLElement
  const dots = document.querySelectorAll<HTMLButtonElement>(
    '#slider-dots button'
  )

  // ── Dots: actualiza el activo al hacer scroll ───────────────────────────────
  const updateDots = () => {
    const itemWidth = scrollContainer.clientWidth * 0.88
    const index = Math.round(scrollContainer.scrollLeft / (itemWidth + 24))
    dots.forEach((dot, i) => {
      const isActive = i === index
      dot.classList.toggle('w-6', isActive)
      dot.classList.toggle('bg-white', isActive)
      dot.classList.toggle('w-2', !isActive)
      dot.classList.toggle('bg-white/35', !isActive)
    })
  }

  scrollContainer.addEventListener('scroll', updateDots, { passive: true })

  // ── Dots: click para navegar ────────────────────────────────────────────────
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      const itemWidth = scrollContainer.clientWidth * 0.88
      scrollContainer.scrollTo({
        left: (itemWidth + 24) * i,
        behavior: 'smooth'
      })
    })
  })

  // ── Video autoplay en mobile: se reproduce solo el slide activo ────────────
  if (window.matchMedia('(max-width: 767px)').matches) {
    const slides = Array.from(scrollContainer.querySelectorAll('li'))

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const videoDiv = entry.target.querySelector(
            '[id="video-subcat"]'
          ) as HTMLElement | null
          const video = entry.target.querySelector(
            'video'
          ) as HTMLVideoElement | null
          if (!videoDiv || !video) return

          if (entry.isIntersecting && entry.intersectionRatio >= 0.7) {
            videoDiv.classList.remove('hidden')
            video.play().catch(() => {})
          } else {
            videoDiv.classList.add('hidden')
            video.pause()
            video.currentTime = 0
          }
        })
      },
      { root: scrollContainer, threshold: 0.7 }
    )

    slides.forEach((slide) => observer.observe(slide))
  }

  // ── Rueda del ratón + trackpad (solo desktop) ───────────────────────────────
  scrollContainer.addEventListener(
    'wheel',
    (event) => {
      if (window.innerWidth < 768) return
      event.preventDefault()

      // Gesto horizontal de trackpad → usar directamente
      if (Math.abs(event.deltaX) > Math.abs(event.deltaY)) {
        scrollContainer.scrollLeft += event.deltaX
        return
      }

      let delta = event.deltaY

      if (event.deltaMode === 1) {
        delta *= 40
      } else if (event.deltaMode === 2) {
        delta *= window.innerHeight
      }

      // Trackpad (delta pequeño) → sin multiplicador; rueda de ratón → ×3
      const isMouseWheel = Math.abs(delta) > 50
      scrollContainer.scrollLeft += isMouseWheel ? delta * 3 : delta
    },
    { passive: false }
  )
</script>
