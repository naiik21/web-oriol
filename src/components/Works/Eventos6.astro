---
interface Props {
  video1: string
  video2: string
  video3: string
  video4: string
}
const { video1, video2, video3, video4 } = Astro.props
---

<div class='flex flex-col justify-center gap-8 md:w-[100%]'>
  <div class='w-auto flex flex-col gap-8 md:flex-row'>
    <iframe
      class='animate-on-scroll w-full md:w-1/2 h-[520px] md:h-[640px]'
      src={video1 + 'preview'}
      allowfullscreen></iframe>

    <iframe
      class='animate-on-scroll w-full md:w-1/2 h-[520px] md:h-[640px]'
      src={video2 + 'preview'}
      allow='autoplay'
      allowfullscreen></iframe>
  </div>
  <div class='w-auto flex flex-col gap-8 md:flex-row'>
    <iframe
      class='animate-on-scroll w-full md:w-1/2 h-[520px] md:h-[640px]'
      src={video3 + 'preview'}
      allow='autoplay'
      allowfullscreen></iframe>

    <iframe
      class='animate-on-scroll w-full md:w-1/2 h-[520px] md:h-[640px]'
      src={video4 + 'preview'}
      allow='autoplay'
      allowfullscreen></iframe>
  </div>
</div>
